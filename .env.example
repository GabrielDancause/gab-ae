# Cloudflare Worker Secrets (set via `npx wrangler secret put <NAME>`)
# These are NOT .env vars — they're set as encrypted secrets in Cloudflare.

OPENROUTER_API_KEY=sk-or-...     # OpenRouter API key (primary LLM provider)
ANTHROPIC_API_KEY=sk-ant-...     # Anthropic API key (fallback, optional)

